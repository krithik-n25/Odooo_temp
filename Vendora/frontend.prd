## 8. ROUTING STRUCTURE

```typescript
// App.tsx
<Routes>
  <Route path="/" element={<Navigate to="/login" />} />
  <Route path="/login" element={<Login />} />

  {/* Procurement Officer */}
  <Route path="/officer" element={<OfficerLayout />}>
    <Route path="dashboard" element={<OfficerDashboard />} />
    <Route path="rfq/create" element={<RFQCreate />} />
    <Route path="rfq/:id" element={<RFQDetail />} />
    <Route path="compare/:rfqId" element={<QuotationComparison />} />
    <Route path="purchase-orders" element={<PurchaseOrders />} />
    <Route path="purchase-orders/:id" element={<PurchaseOrderDetail />} />
    <Route path="invoices" element={<Invoices />} />
    <Route path="invoices/:id" element={<InvoiceDetail />} />
    <Route path="negotiations" element={<Negotiations />} />
    <Route path="negotiations/:threadId" element={<NegotiationThread />} />
  </Route>

  {/* Vendor */}
  <Route path="/vendor" element={<VendorLayout />}>
    <Route path="dashboard" element={<VendorDashboard />} />
    <Route path="rfq/:id" element={<VendorRFQDetail />} />
    <Route path="quote/:rfqId" element={<QuoteSubmit />} />
    <Route path="negotiations" element={<VendorNegotiations />} />
    <Route path="negotiations/:threadId" element={<NegotiationThread />} />
    <Route path="orders" element={<VendorOrders />} />
  </Route>

  {/* Manager */}
  <Route path="/manager" element={<ManagerLayout />}>
    <Route path="dashboard" element={<ManagerDashboard />} />
    <Route path="approval/:id" element={<ApprovalDetail />} />
  </Route>

  {/* Admin */}
  <Route path="/admin" element={<AdminLayout />}>
    <Route path="dashboard" element={<AdminDashboard />} />
    <Route path="reports" element={<Reports />} />
    <Route path="vendors" element={<VendorManagement />} />
    <Route path="users" element={<UserManagement />} />
  </Route>
</Routes>
```

